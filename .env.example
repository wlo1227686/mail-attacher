# ===== Yahoo 帳號（必填）=====
# Yahoo 信箱完整地址
YAHOO_USER=your_account@yahoo.com.tw
# 應用程式密碼（非一般登入密碼！）
# 取得方式：Yahoo 帳號安全設定 → 產生應用程式密碼
YAHOO_APP_PASSWORD=your_app_password_here

# ===== 篩選條件（皆可留空；留空代表不套用該條件，多條件以 AND 組合）=====
# 寄件者，例：billing@example.com
FILTER_FROM=
# 主旨關鍵字，例：發票
FILTER_SUBJECT=
# 日期區間（含起、不含迄），格式 YYYY-MM-DD
FILTER_SINCE=
FILTER_BEFORE=
# 要掃描的信件夾，預設 INBOX
FILTER_MAILBOX=INBOX
# 是否只抓未讀信件：true / false
FILTER_UNSEEN=false
# 第二判斷條件：PDF 附件檔名關鍵字（不分大小寫的子字串比對）。
# 留空則不參考此條件，所有 PDF 都下載；例：invoice 只收檔名含 invoice 的 PDF
FILTER_PDF_NAME=

# ===== 輸出目錄結構 =====
# 下載根目錄（固定，所有東西都放這底下；不存在會自動建立）
DOWNLOAD_DIR=./output
# 主資料夾：PDF 會放在 DOWNLOAD_DIR/<主資料夾>/，例：永豐銀行信用卡
# 留空則 PDF 直接放在 DOWNLOAD_DIR 根目錄
OUTPUT_FOLDER=永豐銀行信用卡

# ===== 行為設定 =====
# 處理完是否將信件標記為已讀：true / false（預設不標記）
MARK_AS_SEEN=false
# 去重：記錄已下載信件的 Message-ID，下次執行時自動跳過（預設開啟）
DEDUPE=true
# 去重狀態檔名（放在 DOWNLOAD_DIR 根層）。可自訂檔名，例：sinopac.processed.json
# 若填入帶路徑或絕對路徑則照填的位置放。
STATE_FILE=processed.json

# ===== 下載檔名規則 =====
# 自訂的固定檔名（即範本裡的 {name}），請改成你要的名稱。
FILENAME_NAME=XXXXXXXXX
# 依信件「發送時間」格式化的日期字串。
# 可用 token：YYYY 年、MM 月、DD 日、HH 時、mm 分、ss 秒；其餘字元（- _ .）原樣保留。
# 例：YYYYMMDD_HHmmss → 20260618_143052
FILENAME_DATE_FORMAT=YYYYMMDD_HHmmss
# 檔名範本，可用佔位符：{name} {date} {from} {subject} {original} {index}
#   {name}=上面的固定檔名  {date}=格式化後的發送時間  {from}=寄件者帳號
#   {subject}=主旨  {original}=原始附件檔名  {index}=同封信第幾個 PDF（1 起算）
# 副檔名 .pdf 會自動補上；同名自動加 _1、_2。
# 預設：{name}.{date} → XXXXXXXXX.20260618_143052.pdf
FILENAME_TEMPLATE={name}.{date}
